# ─── STAGING .env для deploy/stg/compose.yml ──────────────────────────────────
# Скопіюй у `.env` поряд (deploy/stg/.env) і заповни значення.
# Секрети — згенеруй ВІДМІННІ від прод (напр. `openssl rand -hex 32`).

# ─── Неймспейс стека ──────────────────────────────────────────────────────────
# Окремий префікс — щоб staging не конфліктував із прод на тому самому хості
# (ім'я проєкту, контейнери, alias у мережі Zoraxy).
STACK=volunteerfleet-stg

# ─── Образ і мережа ───────────────────────────────────────────────────────────
# Тег релізу (staging піднімається з готового образу, як прод).
VF_IMAGE=ghcr.io/your-org/volunteerfleet:1.0.0
# Зовнішня Docker-мережа, де працює Zoraxy (та сама, що й у прод).
SHARED_NETWORK=n8n_default

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Окремий staging-домен. Має збігатися з тим, що проксіює Zoraxy на upstream
# ${STACK}:3000 (тобто volunteerfleet-stg:3000).
CORS_ORIGIN=https://stg.fleet.example.com

# ─── Database ───────────────────────────────────────────────────────────────--
POSTGRES_USER=volunteerfleet_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=volunteerfleet
# Хост = ІМ'Я СЕРВІСУ postgres у внутрішній мережі стека (стабільне, без префікса).
DATABASE_URL=postgresql://volunteerfleet_user:CHANGE_ME_strong_password@postgres:5432/volunteerfleet

# ─── Auth (секрети ≥ 32 символи) ───────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_to_32_plus_random_chars_xxxxxxxxxx
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=CHANGE_ME_too_to_another_32_plus_random_xxxx
JWT_REFRESH_TTL=30d
BCRYPT_COST=12

# ─── First admin (створюється один раз при першому старті) ──────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_on_first_login
ADMIN_NAME=Адміністратор

# ─── S3 / MinIO ─────────────────────────────────────────────────────────────--
# S3_ENDPOINT — ВНУТРІШНІЙ адрес minio у docker-мережі стека (ім'я сервісу).
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=volunteerfleet-documents
# Креди застосунку до MinIO = root-креди MinIO (значення мають збігатися).
S3_ACCESS_KEY=volunteerfleet_minio
S3_SECRET_KEY=CHANGE_ME_minio_password
MINIO_ROOT_USER=volunteerfleet_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
# (Опційно) Веб-консоль MinIO — лише якщо виставляєш її через Zoraxy на окремий
# сабдомен (Zoraxy → ${STACK}-minio:9001). Розкоментуй у compose.yml
# MINIO_BROWSER_REDIRECT_URL і постав сюди публічний URL консолі:
# MINIO_CONSOLE_URL=https://stg-minio.example.com

# ─── Misc ───────────────────────────────────────────────────────────────────--
EXCHANGE_RATES_FILE=./data/exchange-rates.json
MAX_UPLOAD_BYTES=26214400

# ─── Примітка ───────────────────────────────────────────────────────────────--
# VITE_*-змінні тут НЕ потрібні: фронтенд збирається в образ із відносним /api/v1
# і віддається тим самим контейнером (один origin).
