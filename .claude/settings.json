{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(tree:*)",
      "Bash(echo:*)",
      "Bash(true)",
      "Bash(false)",
      "Bash(which:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(fd:*)",
      "Bash(node --version)",
      "Bash(node -v)",
      "Bash(pnpm --version)",
      "Bash(pnpm -v)",
      "Bash(npm --version)",
      "Bash(mise --version)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git config --get:*)",
      "Bash(git worktree list:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(pnpm list:*)",
      "Bash(pnpm view:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm exec tsc:*)",
      "Bash(pnpm exec eslint:*)",
      "Bash(pnpm exec prettier --check:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker ps:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -r:*)",
      "Bash(rm -f:*)",
      "Bash(rm --recursive:*)",
      "Bash(rm --force:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push origin main:*)",
      "Bash(git push origin master:*)",
      "Bash(git push :main:*)",
      "Bash(git push :master:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git clean -fx:*)",
      "Bash(git clean -f:*)",
      "Bash(git checkout -- .)",
      "Bash(git restore --source:*)",
      "Bash(git restore .)",
      "Bash(git update-ref -d:*)",
      "Bash(git filter-branch:*)",
      "Bash(git filter-repo:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh release delete:*)",
      "Bash(gh pr close:*)",
      "Bash(pnpm publish:*)",
      "Bash(npm publish:*)",
      "Bash(yarn publish:*)",
      "Bash(docker compose down -v:*)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(chmod -R 777:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(npx --yes:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(format:*)"
    ]
  }
}
