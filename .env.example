# ─── App ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ─── Database ─────────────────────────────────────
POSTGRES_USER=volunteerfleet_user
POSTGRES_PASSWORD=change_me_in_local
POSTGRES_DB=volunteerfleet_dev
POSTGRES_PORT=55432
DATABASE_URL=postgresql://volunteerfleet_user:change_me_in_local@localhost:55432/volunteerfleet_dev

# ─── Auth ─────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_to_32_plus_random_chars_xxxxxxxxxx
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change_me_too_to_another_32_plus_random_xxxx
JWT_REFRESH_TTL=30d
BCRYPT_COST=12

# ─── First admin (seed) ───────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_on_first_login
ADMIN_NAME=Адміністратор

# ─── S3 / MinIO ───────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=volunteerfleet-documents
S3_ACCESS_KEY=minio_root
S3_SECRET_KEY=change_me_minio
MINIO_ROOT_USER=minio_root
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── Misc ─────────────────────────────────────────
EXCHANGE_RATES_FILE=./data/exchange-rates.json
MAX_UPLOAD_BYTES=26214400

# ─── Frontend (Vite — VITE_-префікс) ──────────────
# Залиш порожнім/відносним — клієнт ходить через Vite-проксі (/api → server),
# щоб кукі auth були first-party. Прямий http://localhost:3000 ламає cookie-auth (cross-site).
VITE_API_URL=/api/v1
# Кому проксіювати /api у dev (за замовчуванням http://localhost:3000)
VITE_PROXY_TARGET=http://localhost:3000
